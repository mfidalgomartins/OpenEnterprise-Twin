# PostgreSQL is the only supported relational store outside isolated tests.
OPENENTERPRISE_TWIN_DATABASE_URL=postgresql+psycopg://openenterprise_twin:openenterprise_twin@127.0.0.1:5432/openenterprise_twin
OPENENTERPRISE_TWIN_DATABASE_POOL_SIZE=5
OPENENTERPRISE_TWIN_DATABASE_MAX_OVERFLOW=10
OPENENTERPRISE_TWIN_DATABASE_POOL_TIMEOUT_SECONDS=30
OPENENTERPRISE_TWIN_DATABASE_POOL_RECYCLE_SECONDS=1800

# Content-addressed simulation artifacts are generated locally and ignored by git.
OPENENTERPRISE_TWIN_ARTIFACT_DIRECTORY=artifacts
OPENENTERPRISE_TWIN_EXPERIMENT_WORKERS=2
OPENENTERPRISE_TWIN_REPLICATION_WORKERS_PER_EXPERIMENT=4
OPENENTERPRISE_TWIN_EXPERIMENT_SHUTDOWN_TIMEOUT_SECONDS=5
OPENENTERPRISE_TWIN_CORS_ALLOWED_ORIGINS=["http://127.0.0.1:5173"]

# Local developer surfaces used by Makefile targets.
DEV_HOST=127.0.0.1
API_PORT=8000
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://127.0.0.1:8000

# Reproducible flagship demo defaults.
DEMO_SEED=731
DEMO_REPLICATIONS=100
DEMO_TIMEOUT_SECONDS=600
